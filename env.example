# ── 汉语课 · Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# Anthropic API key (sk-ant-...)
ANTHROPIC_KEY=sk-ant-YOUR_KEY_HERE

# Supabase project credentials
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON=YOUR_ANON_KEY_HERE

# Port (Render sets this automatically — leave blank locally to use 3000)
PORT=3000

# Allowed CORS origin in production (set to your Render URL, e.g. https://hanyuke.onrender.com)
# Use * during development
ALLOWED_ORIGIN=*
